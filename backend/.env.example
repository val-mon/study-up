# ─── Base de données ───────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/studyup?retryWrites=true&w=majority

# ─── Serveur ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT (authentification) ────────────────────────────────────
JWT_SECRET=your_secret_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── OTP (code 6 chiffres) ─────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=10

# ─── Frontend URL (pour CORS) ──────────────────────────────────
CLIENT_URL=http://localhost:5173
